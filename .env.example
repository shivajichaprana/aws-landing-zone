# AWS Landing Zone — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# AWS CLI profile for the management account
AWS_PROFILE=management

# Default AWS region for all resources
AWS_REGION=us-east-1

# S3 bucket for Terraform remote state (create this bucket manually first)
TF_STATE_BUCKET=my-org-terraform-state

# DynamoDB table for Terraform state locking
TF_LOCK_TABLE=terraform-state-lock

# Organization display name (used in tags)
ORG_NAME=my-organization
